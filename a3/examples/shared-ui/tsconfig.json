{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "module": "commonjs",
    "declaration": true,
    "declarationDir": "dist",
    "outDir": "dist",
    "noEmit": false
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
